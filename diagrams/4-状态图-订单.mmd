stateDiagram-v2
    [*] --> 待审核 : 用户提交预约(submit)

    待审核 --> 已通过 : 管理员通过订单(confirmOrder)
    待审核 --> 已拒绝 : 管理员拒绝订单(rejectOrder)

    已通过 --> 已完成 : 用户完成订单(finishOrder)
    已通过 --> 待审核 : 用户修改订单(updateOrder)

    已拒绝 --> [*]

    已完成 --> [*]

    待审核 --> [*] : 用户删除订单(delOrder)
    已通过 --> [*] : 用户删除订单(delOrder)

    state 待审核 {
        [*] --> 等待管理员审核
        等待管理员审核 : state = 1
        等待管理员审核 : 订单刚提交，等待审核
    }

    state 已通过 {
        [*] --> 等待用户使用
        等待用户使用 : state = 2
        等待用户使用 : 管理员已审核通过
    }

    state 已完成 {
        [*] --> 订单结束
        订单结束 : state = 3
        订单结束 : 用户确认使用完成
    }

    state 已拒绝 {
        [*] --> 订单失效
        订单失效 : state = 4
        订单失效 : 管理员拒绝，订单作废
    }
