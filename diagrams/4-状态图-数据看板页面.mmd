stateDiagram-v2
    [*] --> 页面空壳 : 管理员点击"数据统计"

    页面空壳 --> 加载概览数据 : AJAX请求 /statistics/overview.do

    state 加载概览数据 {
        [*] --> 请求发送中
        请求发送中 --> 数据返回中 : 服务器查询数据库
        数据返回中 --> 渲染卡片中 : 收到JSON响应
        渲染卡片中 --> 渲染饼图中 : 卡片HTML插入DOM
        渲染饼图中 --> [*] : ECharts绘制饼图
    }

    加载概览数据 --> 加载月度趋势 : AJAX请求 /statistics/monthlyOrders.do

    state 加载月度趋势 {
        [*] --> 请求发送中
        请求发送中 --> 数据返回中 : 服务器查询数据库
        数据返回中 --> 数据倒序处理中 : 收到JSON响应
        数据倒序处理中 --> 渲染折线图中 : 拆分为months和counts数组
        渲染折线图中 --> [*] : ECharts绘制折线图
    }

    加载月度趋势 --> 加载场馆排行 : AJAX请求 /statistics/venueRank.do

    state 加载场馆排行 {
        [*] --> 请求发送中
        请求发送中 --> 查询场馆名中 : 服务器查询订单+场馆表
        查询场馆名中 --> 数据返回中 : 根据venueID查venueName
        数据返回中 --> 渲染柱状图中 : 收到JSON响应
        渲染柱状图中 --> [*] : ECharts绘制柱状图
    }

    加载场馆排行 --> 页面完整展示 : 所有图表渲染完成
    页面完整展示 --> [*]
